{
  "manifest_version": 3,
  "name": "Twitter Consciousness Analyzer",
  "version": "0.1.0",
  "description": "Transform your Twitter bookmarks into deep psychological insights. Analyze your digital consciousness.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["results/results.html", "results/results.css", "results/results.js", "results/history.html", "results/history.css", "results/history.js", "results/about.html", "lib/storage.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
