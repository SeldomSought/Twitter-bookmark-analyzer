{
  "manifest_version": 3,
  "name": "Bookmark Mirror — Consciousness Profiler",
  "version": "2.1.0",
  "description": "Transform your Twitter/X bookmarks into a deep psychological profile. Includes Big Five (OCEAN), Schwartz Values, LIWC linguistic analysis, and more.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "content_scripts": [],
  "web_accessible_resources": [
    {
      "resources": [
        "results/results.html",
        "results/results.css",
        "results/results.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
